# ── Stochastix PRO — Environment Configuration ────────────────────────────
# Copy to .env and adjust. All variables are optional with sane defaults
# (the app runs fully featured on a single machine with no .env at all,
# using DuckDB and no message bus / auth bootstrap).

# ── Database backend ───────────────────────────────────────────────────
# duckdb (default, embedded) | postgres (TimescaleDB, enterprise)
DB_BACKEND=duckdb
STOCHASTIX_DB=stochastix.db

# PostgreSQL / TimescaleDB (used when DB_BACKEND=postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stochastix
POSTGRES_USER=stochastix
POSTGRES_PASSWORD=change-me
POSTGRES_RETENTION_DAYS=30

# ── Streaming backbone ─────────────────────────────────────────────────
# none (default) | kafka | redis
STREAM_BACKEND=none

# Kafka (used when STREAM_BACKEND=kafka)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Redis Streams (used when STREAM_BACKEND=redis)
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_MAXLEN=10000

# ── Authentication (auth/security.py) ─────────────────────────────────
# REQUIRED for any non-local deployment — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Optional: bootstrap a default admin user on first run
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=change-me
